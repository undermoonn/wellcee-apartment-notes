{
  "name": "wellcee-apartment-notes",
  "version": "1.0.1",
  "private": true,
  "description": "A TypeScript 7 and lit-html Chrome extension for private notes on Wellcee apartment listings.",
  "type": "module",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc --noEmit && node scripts/prepare-distribution.mjs && rolldown -c",
    "test": "tsc --noEmit && node scripts/prepare-distribution.mjs && rolldown -c && node --test"
  },
  "engines": {
    "node": ">=20.19"
  },
  "packageManager": "pnpm@11.9.0",
  "dependencies": {
    "lit-html": "3.3.3"
  },
  "devDependencies": {
    "@types/chrome": "0.2.2",
    "rolldown": "1.2.0",
    "typescript": "7.0.2"
  }
}
